{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "ignoreDeprecations": "5.0",
        "paths": {
            "drizzle-orm": ["../../node_modules/drizzle-orm"],
            "drizzle-orm/*": ["../../node_modules/drizzle-orm/*"]
        },
        "types": ["node"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
